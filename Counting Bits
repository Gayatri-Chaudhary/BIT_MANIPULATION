PREREQUISITE is : Count No. of Set bits
class Solution {
    public int[] countBits(int n) {
        int arr[] = new int[n+1];
        for(int i=0;i<arr.length;i++){
            arr[i]=count(i);
        }
        return arr;
    }
    public int count(int n){
        int cnt=0;
        while(n>1){
            cnt=cnt+(n&1);
            n=n>>1;
        }
        if(n==1){
            cnt++;
        }
        return cnt;
    }
}
